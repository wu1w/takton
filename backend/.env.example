# Project Nexus Backend Configuration

# Database
DB_URL=postgresql+asyncpg://user:password@localhost:5432/nexus

# Security
JWT_SECRET=change-me-to-a-secure-random-string
API_KEY=nexus-api-key-change-me

# LLM Provider: ollama | vllm
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2
DEFAULT_MAX_TOKENS=4096

# WebSocket
WS_HEARTBEAT_INTERVAL=30

# Security: 是否启用 Python 代码执行（工作流 + 自定义Skill），默认禁用，仅开发调试时开启
# ENABLE_PYTHON_EXECUTION=true

# RAG Service (placeholder - implement your own)
RAG_SERVICE_CLASS=backend.services.rag.stub.StubRAGService

# Application
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=info
